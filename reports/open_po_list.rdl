<?xml version="1.0" encoding="utf-8"?>
<!--
===============================================================================
Report: Open PO List
File:   reports/open_po_list.rdl
Source: queries/domains/supply_chain/purchasing/open_po_list.sql

Purpose:
    Full list of open PO lines (past-due AND not-yet-due), sorted past-due
    first then by open $ value. Same priority codes as the past-due variant:
        P1 - past due, on open SO
        P2 - past due, no SO linkage
        P3 - not due, on open SO
        P4 - normal
    Includes service POs (lines where SERVICE_ID is populated, with or
    without a PART_ID). Service lines render as "service_id | part_id"
    so it's clear they're not a stock-part purchase.

Audience: Buyer (filtered), purchasing manager.

Parameters:
    Site     - blank = all
    Buyer    - blank = all
    AsOfDate - default today

Notes:
    The past-due-only view is preserved as past_due_po_followup.rdl for
    reference. This report supersedes it for buyer use.
===============================================================================
-->
<Report MustUnderstand="df"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="VECA">
      <rd:SecurityType>None</rd:SecurityType>
      <DataSourceReference>/VECA</DataSourceReference>
      <rd:DataSourceID>6f4e2c8a-9d31-4b67-8a22-1e8f7c2d3e91</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="OpenPO">
      <Query>
        <DataSourceName>VECA</DataSourceName>
        <CommandText><![CDATA[
;WITH open_po AS (
    SELECT p.SITE_ID, p.ID AS po_id, p.VENDOR_ID,
           COALESCE(NULLIF(LTRIM(RTRIM(p.BUYER)), ''), '(unassigned)') AS buyer,
           p.ORDER_DATE, pl.LINE_NO, pl.PART_ID, pl.SERVICE_ID, pl.PURCHASE_UM, pl.UNIT_PRICE AS po_unit_price,
           COALESCE(pd.DEL_SCHED_LINE_NO, 0) AS del_sched_line_no,
           COALESCE(pd.ORDER_QTY, pl.ORDER_QTY, 0) AS sched_order_qty,
           COALESCE(pd.RECEIVED_QTY, 0) AS sched_received_qty,
           COALESCE(pd.DESIRED_RECV_DATE, pl.DESIRED_RECV_DATE,
                    p.PROMISE_DATE, p.DESIRED_RECV_DATE) AS target_recv_date
    FROM PURCHASE_ORDER p
    INNER JOIN PURC_ORDER_LINE pl ON pl.PURC_ORDER_ID = p.ID
    LEFT JOIN PURC_LINE_DEL pd ON pd.PURC_ORDER_ID = pl.PURC_ORDER_ID
        AND pd.PURC_ORDER_LINE_NO = pl.LINE_NO
    WHERE ISNULL(p.STATUS, '') NOT IN ('X','C')
      AND ISNULL(pl.LINE_STATUS, '') NOT IN ('X','C')
      AND (pl.PART_ID IS NOT NULL OR pl.SERVICE_ID IS NOT NULL)
      AND (@Site IS NULL OR @Site='' OR p.SITE_ID = @Site)
),
open_qty AS (
    SELECT o.*, (o.sched_order_qty - o.sched_received_qty) AS open_qty_purchase_um
    FROM open_po o WHERE (o.sched_order_qty - o.sched_received_qty) > 0
),
sales_linked_parts AS (
    SELECT DISTINCT col.SITE_ID, col.PART_ID
    FROM CUST_ORDER_LINE col
    INNER JOIN CUSTOMER_ORDER co ON co.ID = col.CUST_ORDER_ID
    WHERE co.STATUS IN ('R', 'F') AND col.LINE_STATUS = 'A'
      AND col.ORDER_QTY > col.TOTAL_SHIPPED_QTY
),
aged AS (
    SELECT o.*, DATEDIFF(day, o.target_recv_date, @AsOfDate) AS days_past_due,
           CASE WHEN o.target_recv_date >= @AsOfDate THEN 'NOT_DUE'
                WHEN DATEDIFF(day, o.target_recv_date, @AsOfDate) BETWEEN 1 AND 7 THEN '0-7'
                WHEN DATEDIFF(day, o.target_recv_date, @AsOfDate) BETWEEN 8 AND 14 THEN '8-14'
                WHEN DATEDIFF(day, o.target_recv_date, @AsOfDate) BETWEEN 15 AND 30 THEN '15-30'
                WHEN DATEDIFF(day, o.target_recv_date, @AsOfDate) BETWEEN 31 AND 60 THEN '31-60'
                ELSE '61+' END AS aging_bucket
    FROM open_qty o
)
SELECT a.SITE_ID, a.po_id, a.LINE_NO, a.buyer, a.VENDOR_ID,
       v.NAME AS vendor_name, a.PART_ID, a.SERVICE_ID, psv.DESCRIPTION AS part_description,
       a.ORDER_DATE, a.target_recv_date, a.days_past_due, a.aging_bucket,
       a.PURCHASE_UM, a.sched_order_qty, a.sched_received_qty, a.open_qty_purchase_um,
       a.po_unit_price, (a.open_qty_purchase_um * a.po_unit_price) AS open_value,
       CASE WHEN slp.PART_ID IS NOT NULL THEN 1 ELSE 0 END AS is_on_open_sales_order,
       CASE WHEN a.days_past_due > 0 AND slp.PART_ID IS NOT NULL THEN 'P1 - expedite, SO demand'
            WHEN a.days_past_due > 0 THEN 'P2 - past due'
            WHEN slp.PART_ID IS NOT NULL THEN 'P3 - due soon, SO demand'
            ELSE 'P4 - normal' END AS priority
FROM aged a
LEFT JOIN VENDOR v ON v.ID = a.VENDOR_ID
LEFT JOIN PART_SITE_VIEW psv ON psv.SITE_ID = a.SITE_ID AND psv.PART_ID = a.PART_ID
LEFT JOIN sales_linked_parts slp ON slp.SITE_ID = a.SITE_ID AND slp.PART_ID = a.PART_ID
WHERE (@Buyer IS NULL OR @Buyer='' OR a.buyer = @Buyer)
ORDER BY
    CASE a.aging_bucket WHEN '61+' THEN 1 WHEN '31-60' THEN 2 WHEN '15-30' THEN 3
        WHEN '8-14' THEN 4 WHEN '0-7' THEN 5 ELSE 6 END,
    (a.open_qty_purchase_um * a.po_unit_price) DESC;
        ]]></CommandText>
        <QueryParameters>
          <QueryParameter Name="@Site"><Value>=Parameters!Site.Value</Value></QueryParameter>
          <QueryParameter Name="@Buyer"><Value>=Parameters!Buyer.Value</Value></QueryParameter>
          <QueryParameter Name="@AsOfDate"><Value>=Parameters!AsOfDate.Value</Value></QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SITE_ID"><DataField>SITE_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="po_id"><DataField>po_id</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="LINE_NO"><DataField>LINE_NO</DataField><rd:TypeName>System.Int16</rd:TypeName></Field>
        <Field Name="buyer"><DataField>buyer</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="VENDOR_ID"><DataField>VENDOR_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="vendor_name"><DataField>vendor_name</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PART_ID"><DataField>PART_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SERVICE_ID"><DataField>SERVICE_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="part_description"><DataField>part_description</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ORDER_DATE"><DataField>ORDER_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="target_recv_date"><DataField>target_recv_date</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="days_past_due"><DataField>days_past_due</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="aging_bucket"><DataField>aging_bucket</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="open_qty_purchase_um"><DataField>open_qty_purchase_um</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="open_value"><DataField>open_value</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="is_on_open_sales_order"><DataField>is_on_open_sales_order</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="priority"><DataField>priority</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="Site"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><DefaultValue><Values><Value xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" /></Values></DefaultValue><Prompt>Site (blank = all)</Prompt></ReportParameter>
    <ReportParameter Name="Buyer"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><DefaultValue><Values><Value xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" /></Values></DefaultValue><Prompt>Buyer (blank = all)</Prompt></ReportParameter>
    <ReportParameter Name="AsOfDate"><DataType>DateTime</DataType><Nullable>false</Nullable><DefaultValue><Values><Value>=Today()</Value></Values></DefaultValue><Prompt>As Of Date</Prompt></ReportParameter>
  </ReportParameters>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="txtTitle"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Open PO List</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0in</Top><Left>0in</Left><Height>0.3in</Height><Width>6in</Width><ZIndex>1</ZIndex><Style /></Textbox>
          <Textbox Name="txtSubtitle"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Parameters!Site.Value Is Nothing Or Parameters!Site.Value = "", "All Sites", "Site: " &amp; Parameters!Site.Value) &amp; "  |  Buyer: " &amp; IIF(Parameters!Buyer.Value Is Nothing Or Parameters!Buyer.Value = "", "All", Parameters!Buyer.Value) &amp; "  |  As Of: " &amp; Format(Parameters!AsOfDate.Value, "yyyy-MM-dd")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>10pt</FontSize><Color>#555555</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.3in</Top><Left>0in</Left><Height>0.25in</Height><Width>15in</Width><ZIndex>2</ZIndex><Style /></Textbox>
          <Tablix Name="tblxOpenPO">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>1.6in</Width></TablixColumn>
                <TablixColumn><Width>0.6in</Width></TablixColumn>
                <TablixColumn><Width>0.6in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
                <TablixColumn><Width>0.4in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>1.6in</Width></TablixColumn>
                <TablixColumn><Width>1.4in</Width></TablixColumn>
                <TablixColumn><Width>2.0in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.7in</Width></TablixColumn>
                <TablixColumn><Width>0.7in</Width></TablixColumn>
                <TablixColumn><Width>0.7in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.3in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="hPri"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Priority</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hAge"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Age</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hDays"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Days</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hPO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>PO #</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hLn"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Ln</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hBuyer"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Buyer</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hVName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Vendor</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hPart"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Part</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hDesc"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Description</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hOrd"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Ord Date</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hRecv"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Recv By</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hOQ"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Open Qty</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hSO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>On SO</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hVal"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Open $</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.22in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="dPri"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!priority.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><BackgroundColor>=Switch(Left(Fields!priority.Value,2)="P1","#FFCCCC", Left(Fields!priority.Value,2)="P2","#FFE5B4", Left(Fields!priority.Value,2)="P3","#FFF8C4", true, "White")</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dAge"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!aging_bucket.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dDays"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!days_past_due.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N0</Format><Color>=IIF(Fields!days_past_due.Value &gt; 30,"Red","Black")</Color><FontWeight>=IIF(Fields!days_past_due.Value &gt; 30,"Bold","Normal")</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dPO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!po_id.Value</Value><Style><FontFamily>Consolas</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dLn"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LINE_NO.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dBuyer"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!buyer.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dVName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!vendor_name.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dPart"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(IsNothing(Fields!SERVICE_ID.Value) OrElse Fields!SERVICE_ID.Value = "", IIF(IsNothing(Fields!PART_ID.Value), "", Fields!PART_ID.Value), IIF(IsNothing(Fields!PART_ID.Value) OrElse Fields!PART_ID.Value = "", Fields!SERVICE_ID.Value, Fields!SERVICE_ID.Value &amp; " | " &amp; Fields!PART_ID.Value))</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dDesc"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!part_description.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dOrd"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ORDER_DATE.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dRecv"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!target_recv_date.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dOQ"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!open_qty_purchase_um.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N0</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dSO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!is_on_open_sales_order.Value = 1,"Y","-")</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dVal"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!open_value.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>C0</Format><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup><RepeatOnNewPage>true</RepeatOnNewPage></TablixMember><TablixMember><Group Name="Details" /></TablixMember></TablixMembers></TablixRowHierarchy>
            <RepeatColumnHeaders>true</RepeatColumnHeaders>
            <DataSetName>OpenPO</DataSetName>
            <Top>0.7in</Top><Left>0in</Left><Height>0.52in</Height><Width>14.1in</Width><ZIndex>3</ZIndex>
            <Style><Border><Style>None</Style></Border></Style>
          </Tablix>
        </ReportItems>
        <Height>2in</Height><Style />
      </Body>
