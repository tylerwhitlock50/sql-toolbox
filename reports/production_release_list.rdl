                  <TablixCell><CellContents><Textbox Name="dQty"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!RECOMMENDED_BUILD_QTY.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N0</Format><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
