                <TablixRow><Height>0.22in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="dStatus"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ACTION_STATUS.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><BackgroundColor>=Switch(Fields!ACTION_STATUS.Value="RELEASE NOW","#CCFFCC", Fields!ACTION_STATUS.Value="RELEASE NOW (PARTIAL)","#FFF8C4", Fields!ACTION_STATUS.Value="RELEASE NOW (BLOCKED)","#FFCCCC", Fields!ACTION_STATUS.Value="BLOCKED","#FFCCCC", true, "White")</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dRel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!RECOMMENDED_RELEASE_DATE.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format><FontWeight>=IIF(Fields!RECOMMENDED_RELEASE_DATE.Value &lt; Today(),"Bold","Normal")</FontWeight><Color>=IIF(Fields!RECOMMENDED_RELEASE_DATE.Value &lt; Today(),"Red","Black")</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
