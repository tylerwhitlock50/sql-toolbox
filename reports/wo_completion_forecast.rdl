<?xml version="1.0" encoding="utf-8"?>
<!--
===============================================================================
Report: WO Completion Forecast
File:   reports/wo_completion_forecast.rdl
Source: queries/domains/production/performance/fg_completion_forecast.sql

Purpose:
    Predicts realistic finish date per open WO based on remaining labor
    hours, ERP scheduled date, and component readiness. Used by sales /
    CSR for ship-date commitments.

Audience: CSR, sales, plant manager.
Parameters: Site (blank = all)
===============================================================================
-->
<Report MustUnderstand="df"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="VECA">
      <rd:SecurityType>None</rd:SecurityType>
      <DataSourceReference>/VECA</DataSourceReference>
      <rd:DataSourceID>6f4e2c8a-9d31-4b67-8a22-1e8f7c2d3e91</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="WOCompletion">
      <Query>
        <DataSourceName>VECA</DataSourceName>
        <CommandText><![CDATA[
DECLARE @HoursPerDay decimal(5,2) = 8.0;

;WITH
open_wo AS (
    SELECT wo.SITE_ID, wo.TYPE, wo.BASE_ID, wo.LOT_ID, wo.SPLIT_ID, wo.SUB_ID,
           wo.TYPE + '/' + wo.BASE_ID + '/' + wo.LOT_ID + '/' + wo.SPLIT_ID + '/' + wo.SUB_ID AS WO_KEY,
           wo.PART_ID, wo.DESIRED_QTY, wo.RECEIVED_QTY,
           wo.DESIRED_QTY - wo.RECEIVED_QTY AS OPEN_QTY,
           wo.STATUS AS WO_STATUS,
           wo.SCHED_START_DATE, wo.SCHED_FINISH_DATE, wo.DESIRED_WANT_DATE,
           ISNULL(wo.ACT_MATERIAL_COST,0) + ISNULL(wo.ACT_LABOR_COST,0)
             + ISNULL(wo.ACT_BURDEN_COST,0) + ISNULL(wo.ACT_SERVICE_COST,0) AS WIP_VALUE,
           ISNULL(wo.REM_MATERIAL_COST,0) + ISNULL(wo.REM_LABOR_COST,0)
             + ISNULL(wo.REM_BURDEN_COST,0) + ISNULL(wo.REM_SERVICE_COST,0) AS REMAINING_COST
    FROM WORK_ORDER wo
    WHERE wo.TYPE = 'W' AND ISNULL(wo.STATUS,'') NOT IN ('X','C')
      AND wo.DESIRED_QTY > wo.RECEIVED_QTY
      AND (@Site IS NULL OR @Site='' OR wo.SITE_ID = @Site)
),
op_summary AS (
    SELECT wo.WO_KEY,
           SUM(CASE WHEN ISNULL(op.SETUP_HRS,0) > ISNULL(op.ACT_SETUP_HRS,0)
                    THEN ISNULL(op.SETUP_HRS,0) - ISNULL(op.ACT_SETUP_HRS,0) ELSE 0 END
             + CASE WHEN ISNULL(op.RUN_HRS,0) > ISNULL(op.ACT_RUN_HRS,0)
                    THEN ISNULL(op.RUN_HRS,0) - ISNULL(op.ACT_RUN_HRS,0) ELSE 0 END) AS REMAINING_LABOR_HRS,
           MAX(op.SCHED_FINISH_DATE) AS LAST_OP_FINISH,
           SUM(CASE WHEN ISNULL(op.STATUS,'') NOT IN ('X','C','F') THEN 1 ELSE 0 END) AS OPS_OPEN
    FROM open_wo wo
    LEFT JOIN OPERATION op ON op.WORKORDER_TYPE=wo.TYPE AND op.WORKORDER_BASE_ID=wo.BASE_ID
        AND op.WORKORDER_LOT_ID=wo.LOT_ID AND op.WORKORDER_SPLIT_ID=wo.SPLIT_ID
        AND op.WORKORDER_SUB_ID=wo.SUB_ID
    GROUP BY wo.WO_KEY
),
component_check AS (
    SELECT wo.WO_KEY,
           COUNT(*) AS REQ_COUNT,
           SUM(CASE WHEN rq.CALC_QTY - rq.ISSUED_QTY <= ISNULL(psv.QTY_ON_HAND, 0) THEN 0 ELSE 1 END) AS REQS_SHORT,
           SUM(CASE WHEN rq.CALC_QTY - rq.ISSUED_QTY > ISNULL(psv.QTY_ON_HAND, 0)
                    THEN (rq.CALC_QTY - rq.ISSUED_QTY - ISNULL(psv.QTY_ON_HAND, 0))
                         * ISNULL(psv.UNIT_MATERIAL_COST,0)
                    ELSE 0 END) AS COMPONENT_SHORTAGE_VALUE
    FROM open_wo wo
    INNER JOIN REQUIREMENT rq ON rq.WORKORDER_TYPE=wo.TYPE AND rq.WORKORDER_BASE_ID=wo.BASE_ID
        AND rq.WORKORDER_LOT_ID=wo.LOT_ID AND rq.WORKORDER_SPLIT_ID=wo.SPLIT_ID
        AND rq.WORKORDER_SUB_ID=wo.SUB_ID
    LEFT JOIN PART_SITE_VIEW psv ON psv.SITE_ID = wo.SITE_ID AND psv.PART_ID = rq.PART_ID
    WHERE rq.STATUS = 'U' AND rq.PART_ID IS NOT NULL
      AND rq.CALC_QTY > rq.ISSUED_QTY
    GROUP BY wo.WO_KEY
),
so_match AS (
    SELECT wo.SITE_ID, wo.PART_ID,
           SUM(col.ORDER_QTY - col.TOTAL_SHIPPED_QTY) AS OPEN_SO_QTY_FOR_PART,
           SUM((col.ORDER_QTY - col.TOTAL_SHIPPED_QTY) * col.UNIT_PRICE) AS OPEN_SO_VALUE_FOR_PART,
           MIN(COALESCE(col.PROMISE_DATE, col.DESIRED_SHIP_DATE, co.DESIRED_SHIP_DATE)) AS EARLIEST_SO_NEED_DATE
    FROM open_wo wo
    INNER JOIN CUST_ORDER_LINE col ON col.SITE_ID = wo.SITE_ID AND col.PART_ID = wo.PART_ID
    INNER JOIN CUSTOMER_ORDER co ON co.ID = col.CUST_ORDER_ID
    WHERE co.STATUS IN ('R','F') AND col.LINE_STATUS='A'
      AND col.ORDER_QTY > col.TOTAL_SHIPPED_QTY
    GROUP BY wo.SITE_ID, wo.PART_ID
)
SELECT w.SITE_ID, w.WO_KEY, w.PART_ID, psv.DESCRIPTION AS PART_DESCRIPTION,
       w.WO_STATUS, w.DESIRED_QTY, w.RECEIVED_QTY, w.OPEN_QTY,
       CAST(CASE WHEN w.DESIRED_QTY = 0 THEN NULL
                 ELSE 100.0 * w.RECEIVED_QTY / w.DESIRED_QTY END AS decimal(6,2)) AS PCT_COMPLETE_QTY,
       w.SCHED_FINISH_DATE AS WO_SCHED_FINISH, w.DESIRED_WANT_DATE AS WO_NEED_DATE,
       os.REMAINING_LABOR_HRS,
       ISNULL(cc.REQS_SHORT, 0) AS REQS_SHORT,
       CAST(ISNULL(cc.COMPONENT_SHORTAGE_VALUE,0) AS decimal(23,2)) AS COMPONENT_SHORTAGE_VALUE,
       CASE WHEN ISNULL(cc.REQS_SHORT, 0) = 0 THEN 'Y' ELSE 'N' END AS COMPONENTS_READY,
       CASE WHEN ISNULL(os.REMAINING_LABOR_HRS, 0) <= 0 THEN CAST(GETDATE() AS date)
            ELSE DATEADD(day, CEILING(os.REMAINING_LABOR_HRS / @HoursPerDay), CAST(GETDATE() AS date))
       END AS NAIVE_LABOR_FINISH,
       CASE WHEN ISNULL(cc.REQS_SHORT, 0) > 0
            THEN DATEADD(day, 7, COALESCE(w.SCHED_FINISH_DATE, os.LAST_OP_FINISH, CAST(GETDATE() AS date)))
            ELSE COALESCE(w.SCHED_FINISH_DATE, os.LAST_OP_FINISH, CAST(GETDATE() AS date))
       END AS FORECAST_FINISH_DATE,
       CAST(w.WIP_VALUE AS decimal(23,2)) AS WIP_VALUE,
       CAST(w.REMAINING_COST AS decimal(23,2)) AS REMAINING_COST,
       sm.OPEN_SO_QTY_FOR_PART, sm.OPEN_SO_VALUE_FOR_PART, sm.EARLIEST_SO_NEED_DATE,
       CASE WHEN ISNULL(cc.REQS_SHORT, 0) > 0 THEN 'BLOCKED (COMPONENTS SHORT)'
            WHEN COALESCE(w.SCHED_FINISH_DATE, os.LAST_OP_FINISH) < CAST(GETDATE() AS date) THEN 'PAST SCHEDULED FINISH'
            WHEN os.OPS_OPEN = 0 THEN 'OPS COMPLETE - PENDING RECEIPT'
            WHEN sm.EARLIEST_SO_NEED_DATE IS NOT NULL
                 AND COALESCE(w.SCHED_FINISH_DATE, os.LAST_OP_FINISH) > sm.EARLIEST_SO_NEED_DATE
                THEN 'WILL MISS SO PROMISE'
            ELSE 'ON TRACK' END AS COMPLETION_STATUS
FROM open_wo w
LEFT JOIN op_summary os ON os.WO_KEY = w.WO_KEY
LEFT JOIN component_check cc ON cc.WO_KEY = w.WO_KEY
LEFT JOIN PART_SITE_VIEW psv ON psv.SITE_ID=w.SITE_ID AND psv.PART_ID=w.PART_ID
LEFT JOIN so_match sm ON sm.SITE_ID=w.SITE_ID AND sm.PART_ID=w.PART_ID
ORDER BY
    CASE WHEN ISNULL(cc.REQS_SHORT,0) > 0 THEN 1
         WHEN COALESCE(w.SCHED_FINISH_DATE, os.LAST_OP_FINISH) < CAST(GETDATE() AS date) THEN 2
         ELSE 3 END,
    sm.EARLIEST_SO_NEED_DATE, w.SCHED_FINISH_DATE;
        ]]></CommandText>
        <QueryParameters><QueryParameter Name="@Site"><Value>=Parameters!Site.Value</Value></QueryParameter></QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SITE_ID"><DataField>SITE_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="WO_KEY"><DataField>WO_KEY</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PART_ID"><DataField>PART_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PART_DESCRIPTION"><DataField>PART_DESCRIPTION</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="WO_STATUS"><DataField>WO_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="OPEN_QTY"><DataField>OPEN_QTY</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="PCT_COMPLETE_QTY"><DataField>PCT_COMPLETE_QTY</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="WO_SCHED_FINISH"><DataField>WO_SCHED_FINISH</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="WO_NEED_DATE"><DataField>WO_NEED_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="REMAINING_LABOR_HRS"><DataField>REMAINING_LABOR_HRS</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="REQS_SHORT"><DataField>REQS_SHORT</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="COMPONENTS_READY"><DataField>COMPONENTS_READY</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="FORECAST_FINISH_DATE"><DataField>FORECAST_FINISH_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="WIP_VALUE"><DataField>WIP_VALUE</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="OPEN_SO_VALUE_FOR_PART"><DataField>OPEN_SO_VALUE_FOR_PART</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EARLIEST_SO_NEED_DATE"><DataField>EARLIEST_SO_NEED_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="COMPLETION_STATUS"><DataField>COMPLETION_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="Site"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><DefaultValue><Values><Value xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" /></Values></DefaultValue><Prompt>Site (blank = all)</Prompt></ReportParameter>
  </ReportParameters>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="txtTitle"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WO Completion Forecast</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0in</Top><Left>0in</Left><Height>0.3in</Height><Width>6in</Width><ZIndex>1</ZIndex><Style /></Textbox>
          <Textbox Name="txtSubtitle"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Parameters!Site.Value Is Nothing Or Parameters!Site.Value = "", "All Sites", "Site: " &amp; Parameters!Site.Value) &amp; "  |  Generated: " &amp; Format(Now(), "yyyy-MM-dd HH:mm")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>10pt</FontSize><Color>#555555</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.3in</Top><Left>0in</Left><Height>0.25in</Height><Width>15in</Width><ZIndex>2</ZIndex><Style /></Textbox>
          <Tablix Name="tblxWOC">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>1.8in</Width></TablixColumn>
                <TablixColumn><Width>1.6in</Width></TablixColumn>
                <TablixColumn><Width>1.4in</Width></TablixColumn>
                <TablixColumn><Width>2.0in</Width></TablixColumn>
                <TablixColumn><Width>0.6in</Width></TablixColumn>
                <TablixColumn><Width>0.7in</Width></TablixColumn>
                <TablixColumn><Width>0.6in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.3in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="hStat"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Completion Status</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hWO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WO</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hPart"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Part</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hDesc"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Description</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hOpen"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Open</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hPct"><Paragraphs><Paragraph><TextRuns><TextRun><Value>%Done</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hRdy"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Comp Rdy</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hRemHr"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Rem Hrs</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hSched"><Paragraphs><Paragraph><TextRuns><TextRun><Value>ERP Finish</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hForecast"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Forecast</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hSO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>SO Need</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="hWIP"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WIP $</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style></Border><BackgroundColor>#2F5496</BackgroundColor><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.22in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="dStat"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!COMPLETION_STATUS.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><BackgroundColor>=Switch(Fields!COMPLETION_STATUS.Value="ON TRACK","#CCFFCC", Fields!COMPLETION_STATUS.Value="OPS COMPLETE - PENDING RECEIPT","#CCFFFF", Fields!COMPLETION_STATUS.Value="WILL MISS SO PROMISE","#FFE5B4", Fields!COMPLETION_STATUS.Value="PAST SCHEDULED FINISH","#FFCCCC", Fields!COMPLETION_STATUS.Value="BLOCKED (COMPONENTS SHORT)","#FFCCCC", true, "White")</BackgroundColor><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dWO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!WO_KEY.Value</Value><Style><FontFamily>Consolas</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dPart"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PART_ID.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dDesc"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PART_DESCRIPTION.Value</Value><Style><FontFamily>Segoe UI</FontFamily></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dOpen"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!OPEN_QTY.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N0</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dPct"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PCT_COMPLETE_QTY.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N0</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dRdy"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!COMPONENTS_READY.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontWeight>Bold</FontWeight><Color>=IIF(Fields!COMPONENTS_READY.Value = "Y","Black","Red")</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dRemHr"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!REMAINING_LABOR_HRS.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>N1</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dSched"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!WO_SCHED_FINISH.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dForecast"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!FORECAST_FINISH_DATE.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format><FontWeight>Bold</FontWeight><Color>=IIF(IsNothing(Fields!EARLIEST_SO_NEED_DATE.Value),"Black", IIF(Fields!FORECAST_FINISH_DATE.Value &gt; Fields!EARLIEST_SO_NEED_DATE.Value,"Red","Black"))</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dSO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!EARLIEST_SO_NEED_DATE.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>yyyy-MM-dd</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingLeft>4pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="dWIP"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!WIP_VALUE.Value</Value><Style><FontFamily>Segoe UI</FontFamily><Format>C0</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>LightGray</Color><Style>Solid</Style></Border><PaddingRight>4pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
              </TablixRows>
